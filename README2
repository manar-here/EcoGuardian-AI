import os
import shutil
import numpy as np
import matplotlib.pyplot as plt
import tensorflow as tf

# ==========================================
# 1. الإعدادات الأساسية والثوابت (Constants)
# ==========================================
plt.style.use('ggplot')

BATCH_SIZE = 32
IMG_SIZE = (224, 224)
EPOCHS = 15

train_dir = 'dataset/train'
validation_dir = 'dataset/validation'
test_dir = 'dataset/test'

# ==========================================
# 2. تجهيز وترتيب مجلدات التحقق (Validation)
# ==========================================
classes = ['Healthy', 'Moderate', 'Poor']

# إنشاء المجلدات الفرعية إن لم تكن موجودة
for cls in classes:
    os.makedirs(os.path.join(validation_dir, cls), exist_ok=True)

# جلب الصور المبعثرة بالخارج وتوزيعها بالتساوي
loose_files = [f for f in os.listdir(validation_dir) if os.path.isfile(os.path.join(validation_dir, f))]

for i, file_name in enumerate(loose_files):
    if file_name.startswith('.'):  # تجاهل ملفات النظام المؤقتة
        continue
    
    source_path = os.path.join(validation_dir, file_name)
    target_class = classes[i % len(classes)]
    target_path = os.path.join(validation_dir, target_class, file_name)
    
    shutil.move(source_path, target_path)

print("✅ تم تجهيز مجلدات التحقق وتوزيع الصور بنجاح!")

# ==========================================
# 3. تحميل مجموعات البيانات (Data Loading)
# ==========================================
print("\n⏳ جاري تحميل بيانات التدريب...")
train_dataset = tf.keras.utils.image_dataset_from_directory(
    train_dir,
    shuffle=True,
    batch_size=BATCH_SIZE,
    image_size=IMG_SIZE
)

print("\n⏳ جاري تحميل بيانات التحقق...")
validation_dataset = tf.keras.utils.image_dataset_from_directory(
    validation_dir,
    shuffle=False,
    batch_size=BATCH_SIZE,
    image_size=IMG_SIZE
)

print("\n⏳ جاري تحميل بيانات الاختبار...")
test_dataset = tf.keras.utils.image_dataset_from_directory(
    test_dir,
    shuffle=False,
    batch_size=BATCH_SIZE,
    image_size=IMG_SIZE
)

class_names = train_dataset.class_names
print(f"\n✅ تم تحميل كافة البيانات بنجاح! الفئات المكتشفة هي: {class_names}")

# ==========================================
# 4. تسريع الأداء وحفظ البيانات في الذاكرة (Caching)
# ==========================================
AUTOTUNE = tf.data.AUTOTUNE

train_dataset = train_dataset.cache().shuffle(1000).prefetch(buffer_size=AUTOTUNE)
validation_dataset = validation_dataset.cache().prefetch(buffer_size=AUTOTUNE)
test_dataset = test_dataset.cache().prefetch(buffer_size=AUTOTUNE)

print("✅ تم تجهيز مسارات البيانات في الذاكرة لتسريع التدريب.")

# ==========================================
# 5. بناء هيكلية النموذج (CNN Model Architecture)
# ==========================================
model = tf.keras.models.Sequential([
    # إعادة تحجيم بكسلات الصورة لتكون بين [0, 1]
    tf.keras.layers.Rescaling(1./255, input_shape=(224, 224, 3)),
    
    # الطبقة التلافيفية الأولى
    tf.keras.layers.Conv2D(32, (3, 3), activation='relu'),
    tf.keras.layers.MaxPooling2D(2, 2),
    
    # الطبقة التلافيفية الثانية
    tf.keras.layers.Conv2D(64, (3, 3), activation='relu'),
    tf.keras.layers.MaxPooling2D(2, 2),
    
    # الطبقة التلافيفية الثالثة
    tf.keras.layers.Conv2D(128, (3, 3), activation='relu'),
    tf.keras.layers.MaxPooling2D(2, 2),
    
    # تحويل المخرجات لمتجه أحادي البعد والربط بالطبقات الكثيفة
    tf.keras.layers.Flatten(),
    tf.keras.layers.Dense(128, activation='relu'),
    tf.keras.layers.Dropout(0.5), # لتقليل الـ Overfitting
    tf.keras.layers.Dense(3) # مخرجات لـ 3 فئات
])

# تجميع وتحديد إعدادات النموذج
model.compile(
    optimizer='adam',
    loss=tf.keras.losses.SparseCategoricalCrossentropy(from_logits=True),
    metrics=['accuracy']
)

# عرض ملخص الهيكل
model.summary()

# ==========================================
# 6. تدريب النموذج (Model Training)
# ==========================================
print("\n⏳ جاري بدء تدريب النموذج...")
history = model.fit(
    train_dataset,
    validation_data=validation_dataset,
    epochs=EPOCHS
)

# ==========================================
# 7. تقييم النموذج على بيانات الاختبار (Evaluation)
# ==========================================
print("\n⏳ جاري تقييم النموذج على بيانات الاختبار...")
test_loss, test_acc = model.evaluate(test_dataset)
print(f"\n🎯 دقة الاختبار (Test Accuracy): {test_acc:.4f}")
print(f"📉 خسارة الاختبار (Test Loss): {test_loss:.4f}")

# ==========================================
# 8. رسم منحنيات الأداء والتدريب (Plotting)
# ==========================================
acc = history.history['accuracy']
val_acc = history.history['val_accuracy']
loss = history.history['loss']
val_loss = history.history['val_loss']
epochs_range = range(EPOCHS)

plt.figure(figsize=(12, 5))

# رسم بياني للدقة (Accuracy)
plt.subplot(1, 2, 1)
plt.plot(epochs_range, acc, label='Training Accuracy')
plt.plot(epochs_range, val_acc, label='Validation Accuracy')
plt.legend(loc='lower right')
plt.title('Training and Validation Accuracy')

# رسم بياني للخسارة (Loss)
plt.subplot(1, 2, 2)
plt.plot(epochs_range, loss, label='Training Loss')
plt.plot(epochs_range, val_loss, label='Validation Loss')
plt.legend(loc='upper right')
plt.title('Training and Validation Loss')

plt.show()

# ==========================================
# 9. حفظ النموذج المدرب (Save Model)
# ==========================================
model.save('EcoGuardian_model.h5')
print("✅ تم حفظ النموذج بنجاح باسم 'EcoGuardian_model.h5'")

# ==========================================
# 10. دالة التنبؤ وحساب مؤشر الـ ERP
# ==========================================
def predict_image_with_erp(image_path):
    # تحميل النموذج المحفوظ للتنبؤ
    loaded_model = tf.keras.models.load_model('EcoGuardian_model.h5')
    
    # معالجة الصورة واختبارها
    img = tf.keras.utils.load_img(image_path, target_size=(224, 224))
    img_array = tf.keras.utils.img_to_array(img)
    img_array = tf.expand_dims(img_array, 0)
    
    # حساب التوقعات
    predictions = loaded_model.predict(img_array)
    score = tf.nn.softmax(predictions[0])
    
    # خريطة الفئات وتأثيرها على مؤشر ERP
    class_names = ['Healthy', 'Moderate', 'Poor']
    erp_mapping = {
        'Healthy': 'High (🟢 Low Restoration Priority - Well Preserved)',
        'Moderate': 'Medium (🟡 Preventive Action & Monitoring Recommended)',
        'Poor': 'Low (🔴 High Restoration Priority - Action Required)'
    }
    
    predicted_class = class_names[np.argmax(score)]
    confidence = 100 * np.max(score)
    erp_status = erp_mapping[predicted_class]
    
    print("-" * 60)
    print(f"📷 مسار الصورة المختبرة: {image_path}")
    print(f"🏷️ الفئة المتوقعة: {predicted_class} (بنسبة ثقة {confidence:.2f}%)")
    print(f"🌱 مؤشر إمكانية استعادة البيئة (ERP): {erp_status}")
    print("-" * 60)

# اختبار تلقائي على أول صورة متوفرة بمجلد الـ Healthy
test_path = 'dataset/test/Healthy'
available_files = os.listdir(test_path)

if available_files:
    sample_image = os.path.join(test_path, available_files[0])
    predict_image_with_erp(sample_image)
else:
    print("⚠️ لم يتم العثور على صور اختبار داخل 'dataset/test/Healthy'.")
